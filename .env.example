# ─────────────────────────────────────────────────────────────
# EASER Research Data Hub — Environment Variables
# Copy this file to `.env.local` (local dev) and set the values.
# In production, set these in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ---- Firebase (client SDK) — safe to expose, used in the browser ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=easer-521eb.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=easer-521eb
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=easer-521eb.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server only) — NEVER expose ----
# Paste the full service-account JSON as a single-line string, OR set the path.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternatively (local dev): GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ---- GitHub (server only) ----
# A fine-grained PAT or GitHub App installation token with Contents: read/write
# on the easer_repository.
GITHUB_TOKEN=
GITHUB_OWNER=glxriap-7295
GITHUB_REPO=easer_repository
GITHUB_DEFAULT_BRANCH=main
# Strategy on approval: "commit" (direct commit to branch) or "pull_request"
GITHUB_WRITE_STRATEGY=pull_request
# Base directory inside the repo where approved contributions are written
GITHUB_CONTRIB_DIR=contributions

# ---- Storage abstraction ----
# Provider for large/binary uploads: "firebase" | "github" | "local"
# Draft uploads are held OFF GitHub until approval. Default: firestore
# (temporary chunked storage in Firestore). Options: firestore | firebase | github | local
STORAGE_PROVIDER=firestore
MAX_UPLOAD_MB=25

# ---- LLM (documentation generation) ----
# Provider: "anthropic" | "template" (template works fully offline, no key needed)
LLM_PROVIDER=template
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Email notifications ----
# Provider: "console" (logs only) | "smtp" (Gmail) | "resend"
EMAIL_PROVIDER=console
EMAIL_FROM=easer.data@gmail.com
# SMTP (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=easer.data@gmail.com
SMTP_PASS=
# Resend
RESEND_API_KEY=
# Where admin/curator notifications go
ADMIN_EMAIL=easer.data@gmail.com

# ---- Admin access control ----
# Comma-separated list of admin/curator emails (matched against Firebase Auth user)
ADMIN_EMAILS=easer.data@gmail.com,gpurcellmunoz@gmail.com

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
