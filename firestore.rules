rules_version = '2';
// EASER Research Data Hub — Firestore security rules.
// Writes that mutate official state go through server-side API routes using the
// Admin SDK (which bypasses these rules). Client rules below are deliberately
// conservative: the public can read published docs, authenticated users can
// create submissions, and only admins can read/modify the review pipeline.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    function isCurator() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == 'curator');
    }

    // Platform users. The Admin SDK (server) is the only writer — role and
    // profile changes flow through API routes. A user may read their own doc.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if false; // server-only via Admin SDK
    }

    // Contributions: created by anyone (incl. anonymous submitters via API),
    // readable by curators/admins and by the submitter; only curators+ update.
    match /contributions/{id} {
      allow read: if isCurator() ||
        (isSignedIn() && resource.data.submitter.email == request.auth.token.email);
      allow create: if true;        // also validated server-side by API + zod
      allow update, delete: if isCurator();
    }

    // Projects (Phase 3+). Server (Admin SDK) is the only writer; reads are
    // limited to the owner and curators/admins. The public never reads drafts.
    match /projects/{id} {
      allow read: if isCurator() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow write: if false; // server-only via Admin SDK
    }

    // Public registry of APPROVED contributions (denormalised, read-only).
    match /registry/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit log — curator/admin read only, server writes via Admin SDK.
    match /audit/{id} {
      allow read: if isCurator();
      allow write: if false;
    }

    // Team members — public read; server (Admin SDK) is the only writer.
    match /team/{id} {
      allow read: if true;
      allow write: if false;
    }

    // News posts — public read; server (Admin SDK) is the only writer.
    match /news/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Contributor records (public profiles, Phase 6).
    match /contributors/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
