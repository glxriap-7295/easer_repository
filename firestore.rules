rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// EASER Platform — PRODUCTION Firestore security rules (RC1).
//
// Security model:
//   • The website reads Firestore directly for PUBLIC, published content only.
//   • Researchers NEVER write to Firestore from the browser. Every write goes
//     through an authenticated Next.js API route using the Firebase Admin SDK,
//     which BYPASSES these rules. Therefore client writes are denied by default.
//   • Admin/curator actions also run server-side via the Admin SDK.
//
// Net effect: these rules only govern DIRECT client reads. All mutations are
// server-mediated, validated with zod, and authorized with requireRole().
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    // Custom claims are set server-side (users.ts) via the Admin SDK.
    function isAdmin()   { return isSignedIn() && request.auth.token.admin == true; }
    function isCurator() { return isSignedIn() &&
      (request.auth.token.admin == true || request.auth.token.role == 'curator'); }

    // Published, denormalised registry of approved projects → fully public read.
    match /registry/{id} {
      allow read: if true;
      allow write: if false;            // server-only (Admin SDK)
    }

    // Projects — private working data. The public site reads projects through
    // server routes (/api/public/projects) that filter to published status, so
    // direct client reads are limited to the owner and curators/admins.
    match /projects/{id} {
      allow read: if isCurator() ||
        (isSignedIn() && resource.data.ownerUid == request.auth.uid);
      allow write: if false;            // server-only (Admin SDK)
    }

    // Legacy contributions (pre-RC1). Same conservative policy; server-only writes.
    match /contributions/{id} {
      allow read: if isCurator() ||
        (isSignedIn() && resource.data.submitter.email == request.auth.token.email);
      allow write: if false;
    }

    // Team members — public read (Team page is public); server-only writes.
    match /team/{id} {
      allow read: if true;
      allow write: if false;
    }

    // News / Novedades — public read; server-only writes.
    // (The public list route filters to status == 'published'.)
    match /news/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Platform users (profile + role). A user may read ONLY their own document;
    // admins may read all. All writes are server-only via the Admin SDK.
    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if false;
    }

    // Append-only audit log — admin/curator read only; server-only writes.
    match /audit/{id} {
      allow read: if isCurator();
      allow write: if false;
    }

    // Temporary upload staging (chunked file bytes). Never client-readable.
    match /_uploads/{id} {
      allow read, write: if false;      // server-only (Admin SDK)
      match /chunks/{chunkId} {
        allow read, write: if false;
      }
    }

    // Contributor profile records (public), server-only writes.
    match /contributors/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny — any collection not explicitly listed is fully locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
